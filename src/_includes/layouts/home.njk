---
layout: layouts/base.njk
---
{% from "partials/icons.njk" import icon %}
<section class="hero">
  <div class="container">
    <div class="hero-inner">
      <div>
        <span class="hero-eyebrow">Geospatial Lineage · Provenance · Compliance</span>
        <h1>Trace every coordinate, raster, and transform — from acquisition to audit.</h1>
        <p>Implement automated origin tracking, structured transformation audit trails, and metadata sync across raster and vector workflows. Map spatial pipelines to ISO 19115, OGC, INSPIRE, and FISMA controls with Python automation built for production.</p>
        <p>Built for GIS data stewards, Python automation engineers, compliance officers, and government technology teams who need provenance baked into every step of their spatial ETL.</p>
        <div class="cta-row">
          {% for s in site.sections %}
            <a class="cta cta--{{ s.accent }}" href="/{{ s.slug }}/">
              <span class="cta-icon">{{ icon(s.icon) }}</span>
              <span>{{ s.title.split(" & ")[0] }}<br/><small style="opacity:.7;font-weight:500">{{ s.title.split(" & ")[1] or "" }}</small></span>
            </a>
          {% endfor %}
        </div>
      </div>
      <div class="hero-art" aria-hidden="true">
        <svg viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <linearGradient id="ha1" x1="0" y1="0" x2="1" y2="1">
              <stop offset="0%" stop-color="#5e7b4a" stop-opacity=".9"/>
              <stop offset="100%" stop-color="#3f5a30" stop-opacity=".9"/>
            </linearGradient>
            <linearGradient id="ha2" x1="0" y1="1" x2="1" y2="0">
              <stop offset="0%" stop-color="#b85c3b"/>
              <stop offset="100%" stop-color="#d68361"/>
            </linearGradient>
          </defs>
          <!-- grid -->
          <g stroke="#5a3c25" stroke-opacity=".15" stroke-width="1">
            <path d="M0 60h400M0 120h400M0 180h400M0 240h400"/>
            <path d="M80 0v300M160 0v300M240 0v300M320 0v300"/>
          </g>
          <!-- nodes + edges (DAG) -->
          <g fill="none" stroke="#5a3c25" stroke-width="2" opacity=".75">
            <path d="M70 220 C 140 180, 200 230, 260 160 S 340 110, 360 80"/>
            <path d="M70 220 C 110 150, 180 130, 240 90"/>
            <path d="M260 160 C 290 200, 320 220, 360 80"/>
          </g>
          <g>
            <circle cx="70" cy="220" r="14" fill="url(#ha2)"/>
            <circle cx="200" cy="200" r="10" fill="#c8a781"/>
            <circle cx="260" cy="160" r="14" fill="url(#ha1)"/>
            <circle cx="240" cy="90" r="10" fill="#88a373"/>
            <circle cx="360" cy="80" r="16" fill="url(#ha1)"/>
          </g>
          <g font-family="JetBrains Mono, monospace" font-size="11">
            <rect x="28" y="237" width="52" height="16" rx="3" fill="#fbf6ec"/>
            <text x="54" y="249" text-anchor="middle" style="fill:#2b1d12">acquire</text>
            <rect x="165" y="221" width="48" height="16" rx="3" fill="#fbf6ec"/>
            <text x="189" y="233" text-anchor="middle" style="fill:#2b1d12">project</text>
            <rect x="213" y="135" width="28" height="16" rx="3" fill="#fbf6ec"/>
            <text x="227" y="147" text-anchor="middle" style="fill:#2b1d12">join</text>
            <rect x="181" y="69" width="54" height="16" rx="3" fill="#fbf6ec"/>
            <text x="208" y="81" text-anchor="middle" style="fill:#2b1d12">validate</text>
            <rect x="306" y="47" width="44" height="16" rx="3" fill="#fbf6ec"/>
            <text x="328" y="59" text-anchor="middle" style="fill:#2b1d12">publish</text>
          </g>
        </svg>
      </div>
    </div>
  </div>
</section>

{# ---- Start here: surface the strongest pages ---- #}
<section class="start-here">
  <div class="container">
    <h2 class="start-here__heading">Start here</h2>
    <p class="start-here__intro">New to geospatial provenance? These three pages give you the fastest path from zero to a working lineage-aware pipeline.</p>
    <ul class="start-here__list">
      <li>
        <a href="/geospatial-lineage-fundamentals-architecture/provenance-models-for-spatial-data/" class="start-here__link">
          <span class="start-here__num">01</span>
          <span class="start-here__body">
            <strong>Provenance Models for Spatial Data</strong>
            <span>Understand the PROV-O entity–activity–agent graph and how it maps to real GIS workflows before writing a single line of code.</span>
          </span>
          {{ icon("arrow") }}
        </a>
      </li>
      <li>
        <a href="/python-automation-pipeline-integration/automated-hash-generation-for-rasters/" class="start-here__link">
          <span class="start-here__num">02</span>
          <span class="start-here__body">
            <strong>Automated Hash Generation for Rasters</strong>
            <span>SHA-256 fingerprinting is the single fastest win: add tamper-evident checksums to every GeoTIFF in your pipeline today.</span>
          </span>
          {{ icon("arrow") }}
        </a>
      </li>
      <li>
        <a href="/storage-indexing-query-optimization/graph-databases-for-lineage-graphs/" class="start-here__link">
          <span class="start-here__num">03</span>
          <span class="start-here__body">
            <strong>Graph Databases for Lineage Graphs</strong>
            <span>Choose between Neo4j, Amazon Neptune, and RDF triplestores — and learn the schema patterns that make audit traversals fast.</span>
          </span>
          {{ icon("arrow") }}
        </a>
      </li>
      <li>
        <a href="/regulatory-compliance-standards-mapping/" class="start-here__link">
          <span class="start-here__num">04</span>
          <span class="start-here__body">
            <strong>Regulatory Compliance &amp; Standards Mapping</strong>
            <span>Turn your lineage records into audit evidence — map GDPR, FISMA, INSPIRE, and ISO 19115 controls to concrete spatial lineage fields.</span>
          </span>
          {{ icon("arrow") }}
        </a>
      </li>
    </ul>
  </div>
</section>

<section class="sections">
  <div class="container">
    <h2>Explore the four tracks</h2>
    <p style="max-width:62ch;color:var(--mocha);margin-top:-0.5rem">Each track is a deep guide with its own family of how-to pages — from lineage architecture and Python automation to storage design and regulatory compliance. Pick the one that matches your current challenge.</p>
    <div class="section-grid">
      {% for s in site.sections %}
        {% set children = collections.bySection[s.slug] or [] %}
        {% set childCount = (children | length) - 1 %}
        <a class="section-card section-card--{{ s.accent }}" href="/{{ s.slug }}/">
          <span class="card-icon">{{ icon(s.icon) }}</span>
          <h3>{{ s.title }}</h3>
          <p>{{ s.summary }}</p>
          <span class="card-meta">
            <span style="opacity:.65;font-weight:400;font-size:.85em">{{ childCount }} article{% if childCount != 1 %}s{% endif %} &nbsp;·&nbsp;</span>
            Read the guide {{ icon("arrow") }}
          </span>
        </a>
      {% endfor %}
    </div>
  </div>
</section>

<section class="home-pages">
  <div class="container">
    <h2 class="home-pages__heading">All articles</h2>
    <p class="home-pages__intro">Every article in the guide, organised by section — including the section overviews and step-by-step how-to pages.</p>
    <div class="home-pages__grid">
      {% for s in site.sections %}
        {% set children = collections.bySection[s.slug] or [] %}
        {% if children | length %}
        <div class="home-pages__col">
          <h3 class="home-pages__section-title">
            <a href="/{{ s.slug }}/">{{ s.title }}</a>
          </h3>
          <ul class="home-pages__list">
            {% for child in children %}
              <li>
                <a href="{{ child.url }}">{{ child.data.title }}</a>
              </li>
            {% endfor %}
          </ul>
        </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

{{ content | safe }}
